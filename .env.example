# Copy this file to .env.local and fill in one provider setup.
# .env.local is gitignored and loaded automatically by pnpm run test:e2e:llm.

# Preferred: SAP GenAI Hub. Fallback: litellm.
OKF_LLM_PROVIDER=sap-genai-hub

# SAP GenAI Hub example:
# Base URL normally looks like:
# https://api.ai.prod.<region>.aws.ml.hana.ondemand.com
OKF_LLM_BASE_URL=

# SAP GenAI Hub OAuth client-credentials flow.
# If OKF_LLM_TOKEN_URL is set, the e2e test fetches and caches the bearer token.
OKF_LLM_TOKEN_URL=
OKF_LLM_CLIENT_ID=
OKF_LLM_CLIENT_SECRET=

# For SAP GenAI Hub this is the deployment ID, deployment URL, or model name.
# If left empty, the e2e test can discover a RUNNING deployment through
# GET /lm/deployments using OKF_LLM_RESOURCE_GROUP and optional filters below.
# For LiteLLM this is the model name, e.g. gpt-4.1-mini or your routed alias.
OKF_LLM_MODEL=

# SAP deployment discovery model filter. Used only when OKF_LLM_MODEL is empty.
# Matches details.resources.backendDetails.model.name, or name:version.
# Examples: gemini-3.5-flash, gemini-3.5-flash:001, anthropic--claude-4.8-opus
OKF_LLM_MODEL_NAME=

# SAP AI Core deployment lookup. Required only when OKF_LLM_MODEL is empty.
OKF_LLM_RESOURCE_GROUP=
OKF_LLM_DEPLOYMENT_STATUS=RUNNING

# Optional deployment filters for GET /lm/deployments.
OKF_LLM_SCENARIO_ID=
OKF_LLM_CONFIGURATION_ID=
OKF_LLM_EXECUTABLE_IDS=
OKF_LLM_DEPLOYMENT_TOP=100

# SAP GenAI Hub API version. Leave as-is unless your deployment requires another version.
OKF_LLM_API_VERSION=2025-03-01-preview

# Optional. Leave empty for provider/model default. Some models reject temperature=0.
OKF_LLM_TEMPERATURE=

# LiteLLM fallback example:
# OKF_LLM_PROVIDER=litellm
# OKF_LLM_BASE_URL=http://localhost:4000/v1
# OKF_LLM_API_KEY=sk-anything
# OKF_LLM_MODEL=gpt-4.1-mini
